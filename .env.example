# Copy to .env and fill in your values. Do not commit .env.

# Postgres connection string (Supabase, Neon, or self-hosted with pgvector).
# If your password has special characters (@ # / % etc), encode it first:
#   node scripts/encode-password.mjs "YourPassword"
# Then use the output in place of the password in the URL.
DATABASE_URL=postgresql://user:password@host:5432/database

# Embeddings: OpenAI (default), Ollama (free, local), or Google (Gemini).
# Set to "ollama" to use local Ollama with nomic-embed-text (no API key needed).
# Set to "google" or "gemini" to use Google AI Studio (Gemini) for embeddings.
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_PROVIDER=google

# Optional when using Ollama. Defaults to http://localhost:11434.
# OLLAMA_HOST=http://localhost:11434

# Google AI Studio API key (used when EMBEDDING_PROVIDER=google). Get one at https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=

# OpenAI API key (used when EMBEDDING_PROVIDER is not ollama or google).
OPENAI_API_KEY=sk-...
